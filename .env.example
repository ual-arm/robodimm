# Environment Configuration for Robodimm
# Copy this file to .env and adjust values as needed

# Environment: "local" for localhost, "server" for university server
ENV=local

# API Base URL: Leave empty for local, use "/robot" for server
API_BASE_URL=

# Backend host (for uvicorn)
BACKEND_HOST=127.0.0.1

# Backend port
BACKEND_PORT=8000

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
